<idea-plugin>
    <id>com.hezhe.codewhere.jetbrains</id>
    <vendor url="https://plugins.jetbrains.com/vendor/CodeWhere">CodeWhere</vendor>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action
                id="CodeWhere.CopyEditorContext"
                class="com.hezhe.codewhere.jetbrains.actions.CopyCodeWhereDescriptionAction"
                text="Copy CodeWhere Context"
                description="Copies a compact semantic reference for the current editor location or selection">
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift C"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="control shift C"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
