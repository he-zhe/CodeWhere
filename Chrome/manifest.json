{
  "manifest_version": 3,
  "name": "CodeWhere for GitHub",
  "description": "Copy compact CodeWhere context from GitHub file and diff views.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "CodeWhere for GitHub",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "host_permissions": [
    "https://github.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/*/blob/*",
        "https://github.com/*/*/blame/*",
        "https://github.com/*/*/pull/*/files",
        "https://github.com/*/*/commit/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-32.png"
      ],
      "matches": [
        "https://github.com/*"
      ]
    }
  ]
}
